---
import Button from "../shared/atoms/Button.astro";
import Icon from "../shared/atoms/Icon.astro";
import { Instagram, Twitter, Mail } from "@lucide/astro";
---

<section id="contact" class="contact">
  <div class="contact-bg-decoration"></div>
  
  <div class="container contact-container">
    <h2 class="contact-title">¿Listo para tener tu web? Hablemos hoy</h2>
    
    <div class="contact-buttons">
      <Button label="Instagram" href="#" fontFamily="clash">
        <Icon slot="icon" icon={Instagram} size={24} color="black" />
      </Button>

      <Button label="Twitter" href="#" fontFamily="clash">
        <Icon slot="icon" icon={Twitter} size={24} color="black" />
      </Button>

      <Button label="Correo" href="mailto:hola@carlosolcina.com" fontFamily="clash">
        <Icon slot="icon" icon={Mail} size={24} color="black" />
      </Button>
    </div>
  </div>
</section>

<style>
  .contact {
    position: relative;
    padding: 100px 0;
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .contact-bg-decoration {
    position: absolute;
    bottom: -10%;
    left: -10%;
    width: 60%;
    height: 80%;
    background: radial-gradient(circle, var(--accent-start) 0%, var(--accent-end) 100%);
    filter: blur(150px);
    opacity: 0.15;
    z-index: -1;
  }

  .contact-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .contact-title {
    font-family: var(--font-clash);
    font-size: 60px;
    font-weight: 500; /* Medium */
    letter-spacing: 3px;
    margin-bottom: 80px;
    max-width: 900px;
    color: var(--black);
  }

  .contact-buttons {
    display: flex;
    justify-content: center;
    gap: 49px;
    flex-wrap: wrap;
  }

  @media (max-width: 1024px) {
    .contact-title {
      font-size: 48px;
    }
    .contact-buttons {
      gap: 30px;
    }
  }

  @media (max-width: 768px) {
    .contact {
      padding: 60px 0;
    }
    .contact-title {
      font-size: 32px;
      letter-spacing: 1px;
      margin-bottom: 40px;
    }
    .contact-buttons {
      flex-direction: column;
      align-items: center;
      gap: 20px;
      width: 100%;
    }
  }
</style>
