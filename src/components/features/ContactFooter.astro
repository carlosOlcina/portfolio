---
import Button from "../shared/atoms/Button.astro";
import Icon from "../shared/atoms/Icon.astro";
---

<section id="contact" class="contact">
  <div class="contact-bg-decoration"></div>
  
  <div class="container contact-container">
    <h2 class="contact-title">¿Listo para tener tu web? Hablemos hoy</h2>
    
    <div class="contact-buttons">
      <Button label="Instagram" href="#" fontFamily="clash">
        <Icon slot="icon" size={24} color="black">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </Icon>
      </Button>

      <Button label="Twitter" href="#" fontFamily="clash">
        <Icon slot="icon" size={24} color="black">
          <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
        </Icon>
      </Button>

      <Button label="Correo" href="mailto:hola@carlosolcina.com" fontFamily="clash">
        <Icon slot="icon" size={24} color="black">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </Icon>
      </Button>
    </div>
  </div>
</section>

<style>
  .contact {
    position: relative;
    padding: 100px 0;
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .contact-bg-decoration {
    position: absolute;
    bottom: -10%;
    left: -10%;
    width: 60%;
    height: 80%;
    background: radial-gradient(circle, var(--accent-start) 0%, var(--accent-end) 100%);
    filter: blur(150px);
    opacity: 0.15;
    z-index: -1;
  }

  .contact-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .contact-title {
    font-family: var(--font-clash);
    font-size: 60px;
    font-weight: 500; /* Medium */
    letter-spacing: 3px;
    margin-bottom: 80px;
    max-width: 900px;
    color: var(--black);
  }

  .contact-buttons {
    display: flex;
    justify-content: center;
    gap: 49px;
    flex-wrap: wrap;
  }

  @media (max-width: 1024px) {
    .contact-title {
      font-size: 48px;
    }
    .contact-buttons {
      gap: 30px;
    }
  }

  @media (max-width: 768px) {
    .contact {
      padding: 60px 0;
    }
    .contact-title {
      font-size: 32px;
      letter-spacing: 1px;
      margin-bottom: 40px;
    }
    .contact-buttons {
      flex-direction: column;
      align-items: center;
      gap: 20px;
      width: 100%;
    }
  }
</style>
