---
import Button from "../shared/atoms/Button.astro";
import Icon from "../shared/atoms/Icon.astro";
import { Mail, Twitter, Instagram } from "@lucide/astro";
---

<section class="hero">
  <div class="hero-bg-gradient"></div>
  
  <div class="container hero-container">
    <div class="hero-social">
      <div class="hero-social-item">
        <a href="mailto:hola@carlosolcina.com" aria-label="Email">
           <Icon icon={Mail} size={32.727} color="black" />
        </a>
        <span class="social-label">Email</span>
      </div>
      <div class="social-divider"></div>
      <div class="hero-social-item">
        <a href="#" aria-label="Twitter">
          <Icon icon={Twitter} size={32.727} color="black" />
        </a>
        <span class="social-label">Twitter</span>
      </div>
      <div class="social-divider"></div>
      <div class="hero-social-item">
        <a href="#" aria-label="Instagram">
          <Icon icon={Instagram} size={32.727} color="black" />
        </a>
        <span class="social-label">Instagram</span>
      </div>
    </div>

    <div class="hero-content">
      <h1 class="hero-title">
        Tu web lista en <span class="highlight">días</span><br />
        resultados en el primer <span class="highlight">clic</span>
      </h1>
      
      <p class="hero-subtitle">
        Freelance Developer. Apasionado por crear soluciones limpias, eficientes y visualmente atractivas.
      </p>

      <div class="hero-cta">
        <Button label="Contactame" href="#contact">
          <Icon slot="icon" icon={Mail} size={24} color="black" />
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 150px;
    padding-bottom: 100px;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg-gradient {
    position: absolute;
    top: -10%;
    right: -10%;
    width: 80%;
    height: 80%;
    background: radial-gradient(circle, var(--accent-start) 0%, var(--accent-end) 100%);
    filter: blur(150px);
    opacity: 0.15;
    transform: rotate(-3deg);
    z-index: -1;
  }

  .hero-container {
    display: flex;
    align-items: flex-start;
    gap: 80px;
  }

  /* Social Icons Vertical */
  .hero-social {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    padding-top: 20px;
  }

  .hero-social-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    position: relative;
  }

  .social-label {
    font-family: var(--font-mono);
    font-size: 14px;
    transform: rotate(-90deg);
    white-space: nowrap;
    display: none; /* In image they seem to be just icons or rot icons */
  }

  .hero-social-item a {
    display: block;
    transition: transform 0.2s ease;
    transform: rotate(90deg);
  }
  
  .hero-social-item a:hover {
    transform: rotate(90deg) scale(1.1);
  }

  .social-divider {
    width: 1px;
    height: 40px;
    background-color: var(--black);
  }

  /* Hero Content */
  .hero-content {
    max-width: 900px;
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: 60px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 3px;
    margin-bottom: 30px;
  }

  .hero-subtitle {
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 500;
    max-width: 586px;
    line-height: 1.6;
    margin-bottom: 48px;
    color: var(--black);
  }

  .hero-cta {
    display: flex;
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 48px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 120px;
    }
    .hero-container {
      flex-direction: column-reverse;
      gap: 40px;
    }
    .hero-social {
      flex-direction: row;
      width: 100%;
      justify-content: center;
    }
    .social-divider {
      width: 40px;
      height: 1px;
    }
    .hero-title {
      font-size: 36px;
      letter-spacing: 1px;
    }
    .hero-content {
      text-align: center;
    }
    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }
    .hero-cta {
      justify-content: center;
    }
  }
</style>
