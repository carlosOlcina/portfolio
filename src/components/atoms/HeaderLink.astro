---
interface Props {
  href: string;
}

const { href } = Astro.props;

---

<a href={href}>
  <slot></slot>
</a>

<style>
  a {
    display: block;
    
    font-size: 1.1rem;
    transition-property: color, scale;
    transition-duration: 0.2s;
    transition-timing-function: ease-in-out;
  }
  a:hover {
    color: var(--primary-500);
    scale: 1.1;
  }
</style>