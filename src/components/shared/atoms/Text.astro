---
interface Props {
  as?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6' | 'p' | 'span';
  size?: 'xs' | 'sm' | 'base' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl' | '5xl';
  weight?: 'normal' | 'medium' | 'semibold' | 'bold';
  color?: 'neutral-1' | 'neutral-5' | 'neutral-9' | 'neutral-10' | 'green' | 'blue';
  align?: 'left' | 'center' | 'right';
  class?: string;
}

const {
  as: Element = 'p',
  size = 'base',
  weight = 'normal',
  color = 'neutral-9',
  align = 'left',
  class: className,
} = Astro.props;

const colorValues = {
  'neutral-1': '#FFFFFF',
  'neutral-5': '#6D6D6D',
  'neutral-9': '#333333',
  'neutral-10': '#262626',
  'green': '#34C759',
  'blue': '#00C3D0',
};

const selectedColor = colorValues[color as keyof typeof colorValues] || 'inherit';
---

<Element
  class:list={[
    'text',
    `text--${size}`,
    `text--${weight}`,
    `text--align-${align}`,
    className
  ]}
  style={{ color: selectedColor }}
>
  <slot />
</Element>

<style>
  .text {
    margin: 0;
    line-height: 1.5;
    font-family: inherit; /* Hereda "Clash Display" del layout */
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Tamaños */
  .text--xs { font-size: 0.75rem; }
  .text--sm { font-size: 0.875rem; }
  .text--base { font-size: 1rem; }
  .text--lg { font-size: 1.125rem; }
  .text--xl { font-size: 1.25rem; }
  .text--2xl { font-size: 1.5rem; line-height: 1.2; }
  .text--3xl { font-size: 1.875rem; line-height: 1.2; }
  .text--4xl { font-size: 2.25rem; line-height: 1.1; }
  .text--5xl { font-size: 3rem; line-height: 1.1; }

  /* Pesos */
  .text--normal { font-weight: 400; }
  .text--medium { font-weight: 500; }
  .text--semibold { font-weight: 600; }
  .text--bold { font-weight: 700; }

  /* Alineación */
  .text--align-left { text-align: left; }
  .text--align-center { text-align: center; }
  .text--align-right { text-align: right; }

  /* Heading adjustments */
  h1, h2, h3, h4, h5, h6 {
    margin: 0;
  }
</style>
