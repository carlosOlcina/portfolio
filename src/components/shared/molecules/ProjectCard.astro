---
interface Props {
  title: string;
  category: string;
  image: string;
  rotated?: boolean;
}

const { 
  title, 
  category, 
  image, 
  rotated = false 
} = Astro.props;
---

<div class:list={['project-card', { 'project-card--rotated': rotated }]}>
  <div class="project-card__mockup">
    <img src={image} alt={title} class="project-card__image" />
    <div class="project-card__overlay">
      <div class="project-card__text">
        <h3 class="project-card__title">{title}</h3>
        <p class="project-card__category">{category}</p>
      </div>
    </div>
  </div>
</div>

<style>
  .project-card {
    width: 582.218px;
    height: 390.777px;
    background-color: var(--white);
    border-radius: 19.736px;
    overflow: hidden;
    position: relative;
    transition: transform 0.3s ease;
  }

  .project-card--rotated {
    transform: rotate(-3deg);
  }

  .project-card--rotated:hover {
    transform: rotate(-3deg) scale(1.02);
  }

  .project-card:not(.project-card--rotated):hover {
    transform: scale(1.02);
  }

  .project-card__mockup {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    position: relative;
  }

  .project-card__image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .project-card__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, transparent 100%);
    display: flex;
    align-items: flex-end;
    padding: 30px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .project-card--rotated .project-card__overlay {
    opacity: 1; /* Always visible on rotated card as per instructions */
  }

  .project-card:hover .project-card__overlay {
    opacity: 1;
  }

  .project-card__text {
    color: var(--white);
  }

  .project-card--rotated .project-card__text {
    transform: rotate(3deg); /* Counter-rotate text to keep it straight relative to viewport? No, instructions say "Ambos rotados 3 grados" */
    /* If the card is -3, and text is 3, they cancel out. */
  }

  .project-card__title {
    font-family: var(--font-clash);
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .project-card__category {
    font-family: var(--font-clash);
    font-size: 20px;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .project-card {
      width: 100%;
      height: auto;
      aspect-ratio: 582/390;
    }
    .project-card--rotated {
      transform: none;
    }
    .project-card--rotated:hover {
      transform: scale(1.02);
    }
    .project-card--rotated .project-card__text {
      transform: none;
    }
  }
</style>
