---
interface NavItem {
  label: string;
  href: string;
}

interface Props {
  items: NavItem[];
  class?: string;
}

const { items, class: className } = Astro.props;
---

<nav class:list={['navbar', className]}>
  <ul class="navbar__list">
    {items.map((item) => (
      <li class="navbar__item">
        <a href={item.href} class="navbar__link">
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .navbar {
    display: block;
  }

  .navbar__list {
    display: flex;
    align-items: center;
    gap: 33px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .navbar__link {
    color: var(--black);
    text-decoration: none;
    font-size: 16px;
    font-family: var(--font-clash);
    font-weight: 400; /* Regular */
    transition: opacity 0.2s ease-in-out;
  }

  .navbar__link:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .navbar__list {
      gap: 15px;
    }
  }
</style>
