---
import "../styles/reset.css"

---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Carlos Olcina | Portfolio</title>

		<!-- Clash Display -->
		<link href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&display=swap" rel="stylesheet">
		<!-- JetBrains Mono -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400;1,500;1,700&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--white: #FFFFFF;
		--black: #000000;
		--dark-bg: #0C0C0C;
		--accent-start: #00C3D0; /* turquesa */
		--accent-end: #34C759;   /* verde */
		--accent-gradient: linear-gradient(90deg, var(--accent-start) 0%, var(--accent-end) 100%);
		
		--font-clash: "Clash Display", sans-serif;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html,
	body {
		font-family: var(--font-clash);
		background-color: var(--white);
		color: var(--black);
		width: 100%;
		overflow-x: hidden;
	}

	h1, h2, h3, h4, h5, h6 {
		font-family: var(--font-clash);
	}

	p, span, a, button {
		font-family: var(--font-clash);
	}

	.highlight {
		background-color: var(--black);
		color: var(--white);
		padding: 0 8px;
		display: inline-block;
	}

	.container {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 42px;
	}

	@media (max-width: 768px) {
		.container {
			padding: 0 20px;
		}
	}
</style>
