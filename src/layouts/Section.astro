---
interface Props {
  variant?: 'light' | 'dark' | 'none';
  paddingY?: 'none' | 'small' | 'medium' | 'large';
  maxWidth?: 'small' | 'medium' | 'large' | 'none';
  class?: string;
  id?: string;
}

const { 
  variant = 'none', 
  paddingY = 'medium', 
  maxWidth = 'large',
  class: className,
  id
} = Astro.props;
---

<section 
  id={id}
  class:list={[
    'section', 
    `section--${variant}`, 
    `section--padding-${paddingY}`, 
    className
  ]}
>
  <div class:list={['section__container', `section__container--${maxWidth}`]}>
    <slot />
  </div>
</section>

<style>
  .section {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  /* Variantes de Fondo */
  .section--light {
    background-color: #FFFFFF; /* neutral-1 */
    color: #333333; /* neutral-9 */
  }

  .section--dark {
    background-color: #262626; /* neutral-10 */
    color: #FFFFFF; /* neutral-1 */
  }

  /* Variantes de Padding Vertical */
  .section--padding-none { padding: 0; }
  .section--padding-small { padding: 2rem 0; }
  .section--padding-medium { padding: 4rem 0; }
  .section--padding-large { padding: 8rem 0; }

  /* Contenedor Interno */
  .section__container {
    margin: 0 auto;
    padding: 0 1.5rem;
    width: 100%;
    height: 100%;
  }

  /* Variantes de Ancho Máximo */
  .section__container--small { max-width: 640px; }
  .section__container--medium { max-width: 1024px; }
  .section__container--large { max-width: 1280px; }
  .section__container--none { max-width: 100%; }

  @media (min-width: 768px) {
    .section--padding-small { padding: 3rem 0; }
    .section--padding-medium { padding: 6rem 0; }
    .section--padding-large { padding: 10rem 0; }
  }
</style>
